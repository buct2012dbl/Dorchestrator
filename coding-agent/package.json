{
  "name": "coding-agent",
  "version": "0.1.0",
  "description": "Production-grade coding agent system with multi-agent collaboration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "coding-agent": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "keywords": ["ai", "agent", "coding", "llm", "anthropic", "openai"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@ai-sdk/anthropic": "^1.0.5",
    "@ai-sdk/openai": "^1.0.8",
    "@google/generative-ai": "^0.21.0",
    "openai": "^4.77.3",
    "ollama": "^0.5.11",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.36.4",
    "@xenova/transformers": "^2.17.2",
    "chokidar": "^4.0.1",
    "commander": "^12.1.0",
    "inquirer": "^12.0.1",
    "chalk": "^5.3.0",
    "ora": "^8.1.1",
    "cli-table3": "^0.6.5",
    "boxen": "^8.0.1",
    "zod": "^3.23.8",
    "dotenv": "^16.4.7",
    "fast-glob": "^3.3.2",
    "minimatch": "^10.0.1",
    "js-tiktoken": "^1.0.15"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/better-sqlite3": "^7.6.12",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2"
  }
}
